# Copy this to .env and fill in your values.
# docwhisper reads these automatically at startup.

# ── LLM ────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible API key (OpenAI, Groq, Together, Ollama, etc.)
OPENAI_API_KEY=sk-...

# To use a different provider, change the base URL:
# OPENAI_API_BASE=http://localhost:11434/v1   # Ollama
# OPENAI_API_BASE=https://api.groq.com/openai/v1   # Groq

# Model name — must be available at your API_BASE
DOCWHISPER_LLM_MODEL=gpt-4o-mini

# ── Paths ───────────────────────────────────────────────────────────────────
DOCWHISPER_DOCS_DIR=docs/
DOCWHISPER_INDEX_DIR=.docwhisper_index/

# ── Models ──────────────────────────────────────────────────────────────────
# Embedding model (sentence-transformers)
DOCWHISPER_EMBED_MODEL=all-MiniLM-L6-v2

# Cross-encoder reranker
DOCWHISPER_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Retrieval ────────────────────────────────────────────────────────────────
DOCWHISPER_BM25_TOP_K=20
DOCWHISPER_VECTOR_TOP_K=20
DOCWHISPER_RERANK_TOP_K=5

# ── Chunking ─────────────────────────────────────────────────────────────────
DOCWHISPER_CHUNK_SIZE=512
DOCWHISPER_CHUNK_OVERLAP=64

# ── Answer ───────────────────────────────────────────────────────────────────
# Set to false to allow uncited answers (not recommended)
DOCWHISPER_REQUIRE_CITATIONS=true
DOCWHISPER_MIN_CITATIONS=1
